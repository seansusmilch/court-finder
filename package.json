{
  "name": "court-finder",
  "version": "0.0.1",
  "author": "Sean Susmilch",
  "packageManager": "bun@1.2.19",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n S,C \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "convex dev",
    "dev:backend:setup": "convex dev --configure --until-success",
    "dev:frontend": "vite --port=3001",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-routes": "tsr generate",
    "check-types": "bun run generate-routes && tsc --noEmit",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "@auth/core": "^0.40.0",
    "@convex-dev/auth": "^0.0.92",
    "@convex-dev/migrations": "^0.3.4",
    "@hookform/resolvers": "^5.2.2",
    "@mapbox/search-js-react": "^1.5.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.38.0",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.23.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-image-crop": "^11.0.10",
    "react-map-gl": "^8.1.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-cli": "^1.166.43",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  }
}
